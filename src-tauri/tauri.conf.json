{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Pointra",
    "version": "1.0.0",
    "identifier": "com.syjun.pointra",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Pointra",
                "label": "main",
                "url": "src/main/index.html",
                "width": 300,
                "height": 420,
                "visible": false,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "shadow": true,
                "skipTaskbar": true,
                "alwaysOnTop": true
            }
        ],
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/tray-mac.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
